# --- LLM ---
# Format LangChain init_chat_model : "<provider>:<model>"
# Exemples :
#   ollama:qwen2.5-coder:14b
#   ollama:deepseek-coder-v2:16b
#   ollama:llama3.1:8b
#   anthropic:claude-sonnet-4-5
#   openai:gpt-4.1
DEEPAGENT_MODEL=ollama:qwen2.5-coder:14b
OLLAMA_BASE_URL=http://localhost:11434

# Optional: cheaper/faster model for read-only & light sub-agents
# (planner, reviewer, security, docs-writer, i18n). Leave empty to reuse
# DEEPAGENT_MODEL everywhere. Typically a 30-60% cost cut with no quality loss
# on the critical path (coder/debugger keep the strong model).
#   e.g. anthropic:claude-haiku-4-5-20251001  |  openai:gpt-4.1-mini  |  openrouter:...
DEEPAGENT_MODEL_CHEAP=

# Human-in-the-loop: when "1", pause for console approval before destructive
# tools (finalize_patch / codemod_python / ast_grep_rewrite). Default OFF so CI
# / webhook / queue runs stay autonomous. Use the CLI `--interactive` flag too.
DEEPAGENT_INTERACTIVE=0

# --- GitHub : choisis UN des deux modes ---
#
# Mode 1 — Personal Access Token (simple, single-tenant, idéal CLI/local).
# Scopes : repo, workflow, pull_request
GITHUB_TOKEN=ghp_xxx

# Mode 2 — GitHub App (recommandé en prod, multi-tenant, tokens éphémères 1h).
# DEEPAGENT_GITHUB_APP_ID=123456
# DEEPAGENT_GITHUB_APP_PRIVATE_KEY_PATH=/etc/gh-deepagent/app.private-key.pem
# # ou (déconseillé : guillemets + \n échappés) :
# DEEPAGENT_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Optionnel : org/repo par défaut pour la CLI
DEEPAGENT_DEFAULT_REPO=

# --- Agent ---
# Tour max avant abandon (CI safety)
DEEPAGENT_MAX_TURNS=40
# Dossier de travail (cloned repos)
DEEPAGENT_WORKDIR=/tmp/gh-deepagent
# Labels qui déclenchent l'agent
DEEPAGENT_TRIGGER_LABEL=deepagent
DEEPAGENT_REVIEW_LABEL=deepagent-review
# Préfixe des commentaires de commande
DEEPAGENT_COMMAND_PREFIX=/deepagent

# --- Backend (sandbox d'exécution) ---
# local   → LocalShellBackend (par défaut, rapide, pas d'isolation)
# daytona → DaytonaSandbox    (remote, isolé)  → DAYTONA_API_KEY + DAYTONA_API_URL
# modal   → ModalSandbox      (remote, isolé)  → MODAL_TOKEN_ID + MODAL_TOKEN_SECRET
# runloop → RunloopSandbox    (remote, isolé)  → RUNLOOP_API_KEY
DEEPAGENT_BACKEND=local
# DAYTONA_API_KEY=
# DAYTONA_API_URL=
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
# DEEPAGENT_MODAL_APP=gh-deepagent
# DEEPAGENT_MODAL_IMAGE=python:3.12-slim
# RUNLOOP_API_KEY=

# --- Webhook server (optionnel, alternative à GitHub Actions) ---
# Secret HMAC partagé avec ton GitHub App / webhook
DEEPAGENT_WEBHOOK_SECRET=

# --- Queue Redis ---
DEEPAGENT_REDIS_URL=redis://localhost:6379/0
# Nombre de tentatives avant DLQ (1ʳᵉ + retries)
DEEPAGENT_MAX_ATTEMPTS=3

# --- Observability ---
DEEPAGENT_LOG_LEVEL=INFO
# 1 = JSON logs (prod), 0 = pretty logs (dev)
DEEPAGENT_JSON_LOGS=1

# --- OpenTelemetry tracing (optionnel) ---
DEEPAGENT_OTEL_ENABLED=0
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod

# --- Coût LLM (optionnel) ---
# JSON override de PRICE_CATALOG, ex :
# DEEPAGENT_PRICE_OVERRIDES={"openai:my-finetune":{"input":1.5,"output":6.0}}
DEEPAGENT_PRICE_OVERRIDES=

# --- Quota par installation (0 = désactivé) ---
DEEPAGENT_QUOTA_HOUR=0
DEEPAGENT_QUOTA_DAY=0
DEEPAGENT_QUOTA_CONCURRENT=0
# Overrides : DEEPAGENT_QUOTA_OVERRIDES={"1234567":{"hour":100,"day":500,"concurrent":3}}
DEEPAGENT_QUOTA_OVERRIDES=

# --- Alertmanager (optionnel) ---
SLACK_WEBHOOK_URL=
PAGERDUTY_SERVICE_KEY=

# --- Dashboard auth (multi-tenant) ---
# Static admin tokens (comma-separated). Anyone presenting one bypasses scoping.
DEEPAGENT_ADMIN_TOKEN=
# GitHub logins (comma-separated) that are auto-promoted to admin after OAuth login.
DEEPAGENT_ADMIN_GITHUB_LOGINS=
# Turn auth OFF entirely (dev only). NEVER set this in prod.
DEEPAGENT_AUTH_DISABLED=0

# --- OAuth (Streamlit dashboard) ---
# Create a GitHub OAuth App with Device Flow enabled, then put its Client ID here.
DEEPAGENT_OAUTH_CLIENT_ID=

# --- Tracing (optionnel) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=gh-deepagent

# --- Layered memory backend (optional) ---
# When 1, the agent's filesystem is a CompositeBackend that routes
# /memories/<repo>/ to a persistent StoreBackend so observations made in one
# job (conventions, "do not touch" notes…) carry over to the next job on the
# same repo. Defaults to off (per-job ephemeral filesystem only).
DEEPAGENT_LAYERED_MEMORY=0
