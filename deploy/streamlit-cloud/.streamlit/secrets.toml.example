# Local template. NEVER commit the real secrets.toml.
# On Streamlit Community Cloud, configure these in
# Settings → Secrets (TOML editor) — same format.

DEEPAGENT_API_URL = "https://your-webhook.example.com"
DEEPAGENT_OAUTH_CLIENT_ID = "Iv1.xxxxxxxxxxxxxxxx"
# Optional escape hatch — use only for ops scripts, not for users.
# DEEPAGENT_ADMIN_TOKEN = "shared-secret-string"
# DEEPAGENT_ADMIN_GITHUB_LOGINS = "alice,bob"
